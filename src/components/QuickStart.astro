---
---

<section id="quick-start" class="section bg-[#16161f]">
  <div class="section-wide">
    <div class="mx-auto max-w-3xl text-center" data-aos="fade-up">
      <h2 class="text-3xl font-semibold tracking-tight text-[#f0f0f6] sm:text-4xl">
        Up and running in minutes.
      </h2>
      <p class="mt-4 text-lg text-[#9090a8]">
        No accounts, no SaaS, no waiting list.
      </p>
    </div>

    <div class="mx-auto mt-12 grid max-w-4xl min-w-0 gap-6">

      <!-- Step 1: Clone (CLI-agnostic) -->
      <div class="min-w-0" data-aos="fade-up" data-aos-delay="0">
        <div class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#a5b4fc]">
          Step 1 — Clone the repo
        </div>
        <div class="overflow-hidden rounded-lg border border-[#7c3aed]/30 bg-[#0d0d14]">
          <div class="flex items-center gap-2 border-b border-[#7c3aed]/20 bg-[#16161f] px-4 py-2">
            <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
          </div>
          <pre class="overflow-x-auto p-5 font-mono text-sm leading-relaxed text-[#a5b4fc]"><code>git clone https://github.com/crewrig/crewrig.git</code></pre>
        </div>
        <p class="mt-3 text-sm italic text-[#9090a8]">Get a local copy of the framework.</p>
      </div>

      <!-- Step 2: Prerequisites (CLI-agnostic) -->
      <div class="min-w-0" data-aos="fade-up" data-aos-delay="100">
        <div class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#a5b4fc]">
          Step 2 — Install prerequisites
        </div>
        <div class="overflow-hidden rounded-lg border border-[#7c3aed]/30 bg-[#0d0d14] p-5">
          <p class="font-mono text-sm leading-relaxed text-[#9090a8]">
            Read the <a
              href="https://github.com/crewrig/crewrig#prerequisites"
              class="text-[#a5b4fc] underline underline-offset-2 transition hover:text-[#f0f0f6]"
            >README → Prerequisites</a> and install the required tools:<br />
            <span class="mt-2 block text-[#a5b4fc]">Task &nbsp;·&nbsp; Gemini CLI or Claude Code &nbsp;·&nbsp; fzf &nbsp;·&nbsp; uv &nbsp;·&nbsp; yq</span>
          </p>
        </div>
        <p class="mt-3 text-sm italic text-[#9090a8]">OS-specific install commands are in the README.</p>
      </div>

      <!-- CLI toggle -->
      <div class="flex items-center gap-3 min-w-0" data-aos="fade-up" data-aos-delay="200">
        <span id="cli-toggle-label" class="text-sm text-[#9090a8]">Your AI harness:</span>
        <div
          role="tablist"
          aria-labelledby="cli-toggle-label"
          class="flex overflow-hidden rounded-lg border border-[#7c3aed]/30"
        >
          <button
            id="btn-claude"
            role="tab"
            aria-selected="true"
            aria-controls="panel-claude-3 panel-claude-4"
            tabindex="0"
            class="cli-btn cli-btn--active px-4 py-2 text-sm font-semibold transition"
          >Claude Code</button>
          <button
            id="btn-gemini"
            role="tab"
            aria-selected="false"
            aria-controls="panel-gemini-3 panel-gemini-4"
            tabindex="-1"
            class="cli-btn border-l border-[#7c3aed]/30 px-4 py-2 text-sm font-semibold transition"
          >Gemini CLI</button>
        </div>
      </div>

      <!-- Step 3: Initialize — Claude Code -->
      <div id="panel-claude-3" class="min-w-0" data-cli="claude" data-aos="fade-up" data-aos-delay="300">
        <div class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#a5b4fc]">
          Step 3 — Initialize
        </div>
        <div class="overflow-hidden rounded-lg border border-[#7c3aed]/30 bg-[#0d0d14]">
          <div class="flex items-center gap-2 border-b border-[#7c3aed]/20 bg-[#16161f] px-4 py-2">
            <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
          </div>
          <pre class="overflow-x-auto p-5 font-mono text-sm leading-relaxed text-[#a5b4fc]"><code>claude /init-personal-profile
claude /init-soul</code></pre>
        </div>
        <p class="mt-3 text-sm italic text-[#9090a8]">Build your personal profile and customize the agent identity.</p>
      </div>

      <!-- Step 3: Initialize — Gemini CLI -->
      <div id="panel-gemini-3" class="hidden min-w-0" data-cli="gemini" data-aos="fade-up" data-aos-delay="300">
        <div class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#a5b4fc]">
          Step 3 — Initialize
        </div>
        <div class="overflow-hidden rounded-lg border border-[#7c3aed]/30 bg-[#0d0d14]">
          <div class="flex items-center gap-2 border-b border-[#7c3aed]/20 bg-[#16161f] px-4 py-2">
            <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
          </div>
          <pre class="overflow-x-auto p-5 font-mono text-sm leading-relaxed text-[#a5b4fc]"><code>gemini "/init-personal-profile"
gemini "/init-soul"</code></pre>
        </div>
        <p class="mt-3 text-sm italic text-[#9090a8]">Build your personal profile and customize the agent identity.</p>
      </div>

      <!-- Step 4: Setup — Claude Code -->
      <div id="panel-claude-4" class="min-w-0" data-cli="claude" data-aos="fade-up" data-aos-delay="400">
        <div class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#a5b4fc]">
          Step 4 — Setup
        </div>
        <div class="overflow-hidden rounded-lg border border-[#7c3aed]/30 bg-[#0d0d14]">
          <div class="flex items-center gap-2 border-b border-[#7c3aed]/20 bg-[#16161f] px-4 py-2">
            <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
          </div>
          <pre class="overflow-x-auto p-5 font-mono text-sm leading-relaxed text-[#a5b4fc]"><code>task setup-claude-interactive</code></pre>
        </div>
        <p class="mt-3 text-sm italic text-[#9090a8]">Deploys the shared config to your Claude Code harness.</p>
      </div>

      <!-- Step 4: Setup — Gemini CLI -->
      <div id="panel-gemini-4" class="hidden min-w-0" data-cli="gemini" data-aos="fade-up" data-aos-delay="400">
        <div class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#a5b4fc]">
          Step 4 — Setup
        </div>
        <div class="overflow-hidden rounded-lg border border-[#7c3aed]/30 bg-[#0d0d14]">
          <div class="flex items-center gap-2 border-b border-[#7c3aed]/20 bg-[#16161f] px-4 py-2">
            <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
          </div>
          <pre class="overflow-x-auto p-5 font-mono text-sm leading-relaxed text-[#a5b4fc]"><code>task setup-gemini-interactive</code></pre>
        </div>
        <p class="mt-3 text-sm italic text-[#9090a8]">Deploys the shared config to your Gemini CLI harness.</p>
      </div>

    </div>

    <div class="mt-14 flex justify-center" data-aos="fade-up">
      <a
        href="https://github.com/crewrig/crewrig"
        class="inline-flex min-h-[44px] items-center justify-center rounded-lg bg-[#7c3aed] px-6 py-3 font-semibold text-white shadow-lg shadow-[#7c3aed]/30 transition hover:bg-[#8b5cf6]"
      >
        View on GitHub →
      </a>
    </div>
  </div>
</section>

<style>
  .cli-btn {
    background: transparent;
    color: #9090a8;
  }
  .cli-btn--active {
    background: #7c3aed;
    color: #ffffff;
  }
</style>

<script>
  const btnClaude = document.getElementById('btn-claude') as HTMLButtonElement | null;
  const btnGemini = document.getElementById('btn-gemini') as HTMLButtonElement | null;
  const claudeBlocks = document.querySelectorAll('[data-cli="claude"]');
  const geminiBlocks = document.querySelectorAll('[data-cli="gemini"]');

  function selectCli(cli: 'claude' | 'gemini') {
    const isClaude = cli === 'claude';

    // Update active button styles
    btnClaude?.classList.toggle('cli-btn--active', isClaude);
    btnGemini?.classList.toggle('cli-btn--active', !isClaude);

    // Update ARIA state and roving tabindex
    btnClaude?.setAttribute('aria-selected', String(isClaude));
    btnGemini?.setAttribute('aria-selected', String(!isClaude));
    btnClaude?.setAttribute('tabindex', isClaude ? '0' : '-1');
    btnGemini?.setAttribute('tabindex', isClaude ? '-1' : '0');

    // Show / hide panels
    claudeBlocks.forEach(el => el.classList.toggle('hidden', !isClaude));
    geminiBlocks.forEach(el => el.classList.toggle('hidden', isClaude));
  }

  btnClaude?.addEventListener('click', () => { selectCli('claude'); btnClaude.focus(); });
  btnGemini?.addEventListener('click', () => { selectCli('gemini'); btnGemini.focus(); });

  // Keyboard navigation: ArrowRight / ArrowLeft between tabs
  [btnClaude, btnGemini].forEach(btn => {
    btn?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowRight') { selectCli('gemini'); btnGemini?.focus(); }
      if (e.key === 'ArrowLeft')  { selectCli('claude'); btnClaude?.focus(); }
    });
  });
</script>
