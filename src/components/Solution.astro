---
const pillars = [
  {
    label: 'System prompt layers',
    title: 'Layered system prompts',
    description:
      'Personal profile, team norms, expertise, and seniority — structured into a coherent context your AI loads automatically. Configurable per person, shared across your team.',
  },
  {
    label: 'Community zone',
    title: 'Shared skills and agents',
    description:
      'A collaborative sandbox where your team builds and shares reusable skills, custom commands, and agent personas — written once, installed anywhere.',
  },
  {
    label: 'Harness loop',
    title: 'The framework learns from use',
    description:
      'When an agent hits friction, it tags it. A curator clusters the signals, files issues, and ships fixes back into the shared config. Every workflow papercut becomes a permanent improvement.',
  },
];
---

<section id="solution" class="section">
  <div class="section-wide">
    <h2
      class="mb-14 text-center text-3xl font-semibold tracking-tight text-[#f0f0f6] sm:text-4xl"
      data-aos="fade-up"
    >
      Three layers. One coherent stack.
    </h2>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {pillars.map((p, i) => (
        <article
          class="rounded-xl border border-[#7c3aed]/20 border-l-4 border-l-[#7c3aed] bg-[#16161f] p-6 transition hover:bg-[#1a1a26]"
          data-aos="fade-up"
          data-aos-delay={i * 100}
        >
          <div class="mb-2 text-xs font-mono uppercase tracking-widest text-[#a5b4fc]">
            {p.label}
          </div>
          <h3 class="mb-3 text-xl font-semibold text-[#f0f0f6]">{p.title}</h3>
          {/* set:html is safe here: descriptions are hardcoded constants, never user-supplied */}
          <p class="text-[#9090a8] leading-relaxed" set:html={p.description.replace(/`([^`]+)`/g, '<code class="font-mono text-[#a5b4fc]">$1</code>')} />
        </article>
      ))}
    </div>
  </div>
</section>
