---
import '../styles/global.css';
import 'aos/dist/aos.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CrewRig — Multi-agent orchestration for everyday work',
  description = 'CrewRig is an opinionated multi-agent framework that turns a single ticket into a coordinated team of specialist AI agents.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${base}/logo.png`} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      />
    </noscript>
  </head>
  <body class="bg-[#0d0d14] text-slate-100 antialiased font-sans">
    <slot />

    <script>
      import AOS from 'aos';
      // Initialise scroll-triggered animations once the DOM is ready.
      // `once: true` mirrors a marketing page: animate-in, then leave alone.
      AOS.init({
        duration: 700,
        easing: 'ease-out-cubic',
        once: true,
        offset: 80,
      });
    </script>
  </body>
</html>
